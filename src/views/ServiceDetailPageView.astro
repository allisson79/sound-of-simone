---
import SubpageShell from '../components/SubpageShell.astro';
import { homepageContent } from '../config/homepage';
import { serviceMedia, serviceMeta } from '../config/service-media';
import { BOOKING_URL, CONTACT_URL, SERVICES_URL, WAVE_EMBED_STATIC } from '../config/site';

interface Props {
  service: 'physio' | 'women' | 'waves';
}

const { service } = Astro.props;
const content = homepageContent.services[service];
const pageCopy = homepageContent.servicePages[service];
const media = service === 'waves' ? null : serviceMedia[service];
const primaryAction = {
  physio: { href: BOOKING_URL, label: pageCopy.primaryActionLabel },
  women: { href: CONTACT_URL, label: pageCopy.primaryActionLabel },
  waves: { href: CONTACT_URL, label: pageCopy.primaryActionLabel },
}[service];
---

<main class="home-page" id="top">
  <SubpageShell
    eyebrow={serviceMeta[service].eyebrow}
    title={content.title}
    lead={pageCopy.detailLead}
    media={media ?? undefined}
    primaryActionHref={primaryAction.href}
    primaryActionLabel={primaryAction.label}
  >
    {
      service === 'waves' && (
        <div slot="media" class="subpage-shell__wave-frame">
          <div class="services-wave-teaser services-wave-teaser--large" aria-hidden="true">
            <iframe src={WAVE_EMBED_STATIC} title="Dekorativt bolgesymbol" loading="lazy"></iframe>
          </div>
        </div>
      )
    }

    {
      service === 'physio' && (
        <div class="subpage-grid subpage-grid--content-aside">
          <article class="subpage-card">
            <h2 class="subpage-card__title">{pageCopy.detailTitle}</h2>
            <p class="subpage-card__body">{homepageContent.services.physio.lead}</p>
            <div class="subpage-pill-list" aria-label="Temaer i Sound of Physio">
              {homepageContent.services.physio.moreTopics.map((topic) => <span class="subpage-pill">{topic}</span>)}
            </div>
          </article>

          <aside class="subpage-card subpage-card--support">
            <p class="subpage-card__eyebrow">{pageCopy.supportEyebrow}</p>
            <p class="subpage-card__body">{pageCopy.supportBody}</p>
            <div class="subpage-card__actions">
              <a href={SERVICES_URL} class="subpage-text-link">Tilbake til tjenester</a>
            </div>
          </aside>
        </div>
      )
    }

    {
      service === 'women' && (
        <div class="subpage-grid subpage-grid--content-aside">
          <article class="subpage-card">
            <h2 class="subpage-card__title">{pageCopy.detailTitle}</h2>
            <div class="subpage-nested-grid">
              {homepageContent.services.women.blocks.map((block) => (
                <article class="subpage-mini-card">
                  <h3>{block.title}</h3>
                  <p>{block.body}</p>
                </article>
              ))}
            </div>
          </article>

          <aside class="subpage-card subpage-card--support">
            <p class="subpage-card__eyebrow">{pageCopy.supportEyebrow}</p>
            <p class="subpage-card__body">{pageCopy.supportBody}</p>
            <div class="subpage-card__actions">
              <a href={SERVICES_URL} class="subpage-text-link">Tilbake til tjenester</a>
            </div>
          </aside>
        </div>
      )
    }

    {
      service === 'waves' && (
        <div class="subpage-grid subpage-grid--content-aside">
          <article class="subpage-card">
            <h2 class="subpage-card__title">{pageCopy.detailTitle}</h2>
            <p class="subpage-card__body">{homepageContent.services.waves.lead}</p>
            <p class="services-launch-pill">{homepageContent.services.waves.launchLabel}</p>
          </article>

          <aside class="subpage-card subpage-card--support">
            <p class="subpage-card__eyebrow">{pageCopy.supportEyebrow}</p>
            <p class="subpage-card__body">{pageCopy.supportBody}</p>
            <div class="subpage-card__actions">
              <a href={SERVICES_URL} class="subpage-text-link">Tilbake til tjenester</a>
            </div>
          </aside>
        </div>
      )
    }
  </SubpageShell>
</main>
