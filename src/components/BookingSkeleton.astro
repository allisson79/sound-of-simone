---
import { homepageContent } from '../config/homepage';
---

<div class="subpage-grid subpage-grid--content-aside">
  <article class="subpage-card">
    <h2 class="subpage-card__title">{homepageContent.bookingPage.sectionTitle}</h2>
    <p class="subpage-card__body">{homepageContent.bookingPage.lead}</p>
    <p class="subpage-status">{homepageContent.bookingPage.statusLabel}</p>
  </article>

  <aside class="subpage-card subpage-card--support">
    <p class="subpage-card__eyebrow">{homepageContent.bookingPage.nextStepEyebrow}</p>
    <p class="subpage-card__body">{homepageContent.bookingPage.nextStepBody}</p>
  </aside>
</div>
