---
import { homepageContent } from '../config/homepage';
---

<div class="subpage-grid subpage-grid--content-aside">
  <article class="subpage-card">
    <h2 class="subpage-card__title">{homepageContent.contactPage.directTitle}</h2>
    <div class="subpage-contact-list">
      <a href={`mailto:${homepageContent.contact.email}`} class="contact-link">{homepageContent.contact.email}</a>
      <a href={`tel:${homepageContent.contact.phoneLink}`} class="contact-link">
        Tlf: {homepageContent.contact.phoneDisplay}
      </a>
      {homepageContent.contact.address && <p class="contact-address">{homepageContent.contact.address}</p>}
    </div>
  </article>

  <aside class="subpage-card subpage-card--support">
    <p class="subpage-card__eyebrow">{homepageContent.contactPage.supportEyebrow}</p>
    <p class="subpage-card__body">{homepageContent.contactPage.supportBody}</p>
  </aside>
</div>
