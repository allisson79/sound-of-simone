---
import Layout from '../../../layouts/Layout.astro';
import Container from '../../../components/ui/Container.astro';
import { BLOG_WELCOME_URL } from '../../../config/site';
---

<Layout title="Blogg">
  <Container size="md">
    <main class="py-12">
      <header class="mb-8 text-center">
        <h1 class="text-4xl font-bold mb-4">Blogg</h1>
        <p class="text-lg text-secondary">Forhåndsvisning av innlegg som ikke skal være offentlige ennå.</p>
      </header>

      <article class="card-preview">
        <h2 class="text-2xl font-bold mb-3">Welcome to the Blog</h2>
        <p class="text-secondary mb-4">Første innlegg i preview-treet.</p>
        <a href={BLOG_WELCOME_URL} class="hero-btn hero-btn--primary">Åpne innlegget</a>
      </article>
    </main>
  </Container>
</Layout>

<style>
  .card-preview {
    border: 1px solid var(--color-border-light);
    border-radius: var(--border-radius-xl);
    padding: var(--space-6);
    background: var(--color-bg-primary);
  }
</style>
